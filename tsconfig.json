{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "sourceMap": true,
    "types": ["vitest/globals"]
  },
  "include": [],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "./packages/css" },
    { "path": "./packages/dbsync" },
    { "path": "./packages/dbsync/tsconfig.test.json" },
    { "path": "./packages/demo" },
    { "path": "./packages/forms" },
    { "path": "./packages/markdown" },
    { "path": "./packages/mdi-paths" },
    { "path": "./packages/react" },
    { "path": "./packages/react-util" },
    { "path": "./packages/router" },
    { "path": "./packages/styled" },
    { "path": "./packages/swr" },
    { "path": "./packages/util" }
  ]
}
