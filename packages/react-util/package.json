{
	"name": "@slimr/react-util",
	"version": "1.0.4",
	"author": "Brian Dombrowski",
	"license": "ISC",
	"private": false,
	"sideEffects": false,
	"keywords": [
		"react",
		"hooks"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bdombro/slimr.git"
	},
	"type": "module",
	"main": "./cjs/index.js",
	"module": "./esm/index.js",
	"exports": {
		".": {
			"require": "./cjs/index.js",
			"import": "./esm/index.js"
		}
	},
	"scripts": {
		"build": "run-p build:*",
		"build:esm": "OUT=esm; tsc -d --outDir $OUT --noEmit false",
		"build:cjs": "OUT=cjs; tsc -d -m commonjs --moduleResolution node --outDir $OUT --noEmit false",
		"clean": "rm -rf esm cjs"
	},
	"files": [
		"cjs",
		"esm",
		"README.md"
	],
	"dependencies": {
		"@slimr/util": "^3.2.78"
	},
	"peerDependencies": {
		"@types/react": "*",
		"@types/react-dom": "*",
		"react": "*",
		"react-dom": "*"
	}
}
