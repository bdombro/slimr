{
  "name": "@slimr/router",
  "version": "3.0.5",
  "author": "Brian Dombrowski",
  "license": "ISC",
  "private": false,
  "sideEffects": false,
  "keywords": [
    "react-router",
    "preact",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdombro/slimr.git"
  },
  "type": "module",
  "types": "esm/index.d.ts",
  "main": "./cjs/index.cjs",
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs"
    }
  },
  "scripts": {
    "build": "bun ../../scripts/cli.ts build-lib --pkg .",
    "clean": "rm -rf esm cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "start": "nodemon -w src -e '*' -x 'npm run build && cd ../demo && npm start'"
  },
  "files": [
    "cjs",
    "esm",
    "README.md"
  ],
  "dependencies": {
    "@slimr/observable": "^0.0.6"
  },
  "peerDependencies": {
    "@types/react": "*",
    "@types/react-dom": "*",
    "react": "*",
    "react-dom": "*"
  }
}
