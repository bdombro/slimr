{
  "name": "@slimr/util",
  "version": "3.2.79",
  "author": "Brian Dombrowski",
  "license": "ISC",
  "private": false,
  "main": "cjs/index.cjs",
  "module": "esm/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "require": "./cjs/index.cjs",
      "import": "./esm/index.js"
    },
    "./code-highlight": {
      "require": "./cjs/code-highlight.cjs",
      "import": "./esm/code-highlight.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdombro/slimr.git"
  },
  "type": "module",
  "types": "esm/index.d.ts",
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts --pkg .",
    "clean": "rm -rf esm cjs",
    "typecheck": "tsc -b",
    "start": "nodemon -w src -e '*' -x 'npm run build && cd ../demo && npm start'"
  },
  "files": [
    "cjs",
    "esm"
  ],
  "dependencies": {
    "copy-anything": "3.0.3",
    "deep-object-diff": "1.1.9",
    "fast-deep-equal": "3.1.3",
    "fast-shallow-equal": "1.0.0",
    "highlight.js": "11.7.0",
    "is-what": "4.1.8",
    "merge-anything": "5.1.4",
    "nanoid": "4.0.1"
  }
}
