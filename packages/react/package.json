{
  "name": "@slimr/react",
  "version": "4.0.11",
  "author": "Brian Dombrowski",
  "license": "ISC",
  "private": false,
  "sideEffects": false,
  "keywords": [
    "preact",
    "react",
    "swr"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdombro/slimr.git"
  },
  "type": "module",
  "types": "esm/index.d.ts",
  "main": "./cjs/index.cjs",
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs"
    }
  },
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts --pkg .",
    "clean": "rm -rf esm cjs",
    "typecheck": "tsc -b",
    "start": "nodemon -w src -e '*' -x 'npm run build && cd ../demo && npm start'"
  },
  "files": [
    "cjs",
    "esm",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@slimr/forms": "^5.0.53",
    "@slimr/markdown": "^2.1.93",
    "@slimr/react-util": "^2.0.1",
    "@slimr/router": "^2.1.100",
    "@slimr/styled": "^2.1.100",
    "@slimr/swr": "^2.1.79"
  },
  "peerDependencies": {
    "@types/react": "*",
    "@types/react-dom": "*",
    "react": "*",
    "react-dom": "*"
  }
}
