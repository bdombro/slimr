{
  "name": "@slimr/markdown",
  "version": "2.1.92",
  "author": "Brian Dombrowski",
  "license": "ISC",
  "private": false,
  "sideEffects": false,
  "keywords": [
    "markdown",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdombro/slimr.git"
  },
  "type": "module",
  "types": "esm/index.d.ts",
  "main": "./cjs/index.cjs",
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "require": "./cjs/index.cjs",
      "import": "./esm/index.js"
    }
  },
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts --pkg .",
    "clean": "rm -rf esm cjs",
    "start": "nodemon -w src -e '*' -x 'npm run build && cd ../demo && npm start'"
  },
  "files": [
    "cjs",
    "esm",
    "README.md"
  ],
  "dependencies": {
    "@slimr/util": "^3.2.79"
  },
  "optionalDependencies": {
    "react": "*",
    "react-dom": "*"
  }
}
