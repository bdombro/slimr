{
  "name": "@slimr/forms",
  "version": "5.0.54",
  "author": "Brian Dombrowski",
  "license": "ISC",
  "private": false,
  "sideEffects": false,
  "keywords": [
    "preact",
    "react",
    "forms"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdombro/slimr.git"
  },
  "type": "module",
  "types": "esm/index.d.ts",
  "main": "./cjs/index.cjs",
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs"
    }
  },
  "scripts": {
    "build": "bun ../../scripts/cli.ts build-lib --pkg .",
    "clean": "rm -rf esm cjs",
    "typecheck": "tsc -b"
  },
  "files": [
    "cjs",
    "esm",
    "README.md"
  ],
  "dependencies": {
    "@slimr/util": "^3.2.80"
  },
  "peerDependencies": {
    "@types/react": "*",
    "@types/react-dom": "*",
    "react": "*",
    "react-dom": "*"
  }
}
