{
  "name": "@slimr/dbsync",
  "version": "0.0.35",
  "author": "Brian Dombrowski",
  "license": "ISC",
  "private": false,
  "main": "cjs/index.cjs",
  "module": "esm/index.js",
  "sideEffects": false,
  "keywords": [
    "indexeddb",
    "offline-first",
    "local-first",
    "sync",
    "orm",
    "pwa",
    "react",
    "cross-tab",
    "broadcast-channel",
    "mutation-queue",
    "schema-migration"
  ],
  "exports": {
    ".": {
      "require": "./cjs/index.cjs",
      "import": "./esm/index.js"
    },
    "./adapters": {
      "require": "./cjs/adapters/index.cjs",
      "import": "./esm/adapters/index.js"
    },
    "./react": {
      "require": "./cjs/react.cjs",
      "import": "./esm/react.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdombro/slimr.git"
  },
  "type": "module",
  "types": "esm/index.d.ts",
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts --pkg .",
    "clean": "rm -rf esm cjs",
    "start": "nodemon -w src -e '*' -x 'npm run build && cd ../demo && npm start'",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck:test": "tsc -b tsconfig.test.json",
    "typecheck": "tsc -b"
  },
  "files": [
    "docs",
    "cjs",
    "esm"
  ],
  "dependencies": {
    "@slimr/util": "^3.2.79"
  }
}
