{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": ".tsbuild-test",
    "rootDir": "."
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/test-support/**/*.ts",
    "playwright/**/*.ts",
    "playwright/**/*.d.ts"
  ],
  "references": [{ "path": "./tsconfig.json" }]
}
