{
  "name": "@slimr/fuzz",
  "version": "0.0.9",
  "author": "Brian Dombrowski",
  "license": "ISC",
  "private": false,
  "sideEffects": false,
  "keywords": [
    "fuzzy",
    "search",
    "substring",
    "filter",
    "autocomplete",
    "typeahead",
    "index",
    "in-memory",
    "weighted",
    "lightweight"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdombro/slimr.git"
  },
  "type": "module",
  "types": "esm/index.d.ts",
  "main": "./cjs/index.cjs",
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs"
    }
  },
  "scripts": {
    "build": "bun ../../scripts/cli.ts build-lib --pkg .",
    "clean": "rm -rf esm cjs",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "files": [
    "cjs",
    "esm",
    "README.md"
  ],
  "dependencies": {
    "@slimr/util": "^3.2.80"
  }
}
