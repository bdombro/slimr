{
  "name": "@slimr/styled",
  "version": "2.1.101",
  "author": "Brian Dombrowski",
  "license": "ISC",
  "private": false,
  "sideEffects": false,
  "keywords": [
    "chakra",
    "chakra-ui",
    "emotion",
    "styled-components",
    "preact",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdombro/slimr.git"
  },
  "type": "module",
  "types": "esm/index.d.ts",
  "main": "./cjs/index.cjs",
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs"
    }
  },
  "scripts": {
    "build": "bun ../../scripts/cli.ts build-lib --pkg .",
    "clean": "rm -rf esm cjs",
    "typecheck": "tsc -b"
  },
  "files": [
    "cjs",
    "esm",
    "README.md"
  ],
  "peerDependencies": {
    "@types/react": "*",
    "@types/react-dom": "*",
    "react": "*",
    "react-dom": "*"
  },
  "dependencies": {
    "@slimr/css": "^2.1.97",
    "@slimr/util": "^3.2.80"
  }
}
